{
  "name": "asset-tracker",
  "version": "0.1.0",
  "description": "Plug-and-play asset tracking adapter library + 3D CesiumJS map.",
  "type": "module",
  "main": "src/registry.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"src/**/*.{js,html}\" \"tests/**/*.js\"",
    "serve": "python3 -m http.server 8080"
  },
  "keywords": [
    "asset-tracking",
    "cesium",
    "gps",
    "ads-b",
    "adapter"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ]
}
