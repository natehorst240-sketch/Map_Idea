{
  "name": "asset-tracker",
  "version": "0.2.0",
  "description": "Plug-and-play asset tracking adapter library + 3D MapLibre + deck.gl map.",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./registry": {
      "types": "./src/registry.d.ts",
      "default": "./src/registry.js"
    },
    "./adapters/*": {
      "types": "./src/adapters/*.d.ts",
      "default": "./src/adapters/*.js"
    },
    "./map/*": {
      "types": "./src/map/*.d.ts",
      "default": "./src/map/*.js"
    },
    "./ui/*": {
      "types": "./src/ui/*.d.ts",
      "default": "./src/ui/*.js"
    }
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "typecheck": "tsc -p tests/typecheck/tsconfig.json",
    "format": "prettier --write \"src/**/*.{js,html}\" \"tests/**/*.js\"",
    "serve": "python3 -m http.server 8080"
  },
  "keywords": [
    "asset-tracking",
    "maplibre",
    "deck.gl",
    "gps",
    "ads-b",
    "ais",
    "aivdm",
    "nmea",
    "aprs",
    "traccar",
    "samsara",
    "inreach",
    "mqtt",
    "geojson",
    "adapter"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/natehorst240-sketch/Map_Idea"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testPathIgnorePatterns": ["/node_modules/", "/tests/typecheck/"]
  },
  "files": [
    "src",
    "config.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false
}
